# ── Kimi API (storyboard-service) ─────────────────────────────────────────────
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
STORYBOARD_PROVIDER=kimi

# ── TTS (tts-service) ─────────────────────────────────────────────────────────
TTS_PROVIDER=edge_tts
TTS_ACTION_VOICE=zh-CN-YunxiNeural
TTS_DIALOGUE_VOICE=zh-CN-XiaoxiaoNeural

# ── Image (image-service) ─────────────────────────────────────────────────────
IMAGE_PROVIDER=flux_local
FLUX_MODEL_PATH=/app/models/FLUX.1-dev

# ── Video (video-service) ─────────────────────────────────────────────────────
VIDEO_PROVIDER=wan_local
WAN_MODEL_PATH=/app/models/Wan2.1-T2V-1.3B
WAN_GENERATE_TIMEOUT=600

# ── Shared ────────────────────────────────────────────────────────────────────
PROJECTS_BASE_DIR=/app/projects
MODEL_TTL_SECONDS=600

# ── Mock mode (set to "true" to skip real AI inference) ───────────────────────
MOCK_MODE=false

# ── Next.js — service URLs (Docker service names inside compose) ──────────────
STORYBOARD_SERVICE_URL=http://storyboard-service:8000
IMAGE_SERVICE_URL=http://image-service:8000
TTS_SERVICE_URL=http://tts-service:8000
VIDEO_SERVICE_URL=http://video-service:8000
ASSEMBLY_SERVICE_URL=http://assembly-service:8000
